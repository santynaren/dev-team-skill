              "type": "listItem",
              "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "POST /api/auth/login accepts email and password" }] }]
            },
            {
              "type": "listItem",
              "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "Returns JWT token on successful authentication" }] }]
            },
            {
              "type": "listItem",
              "content": [{ "type": "paragraph", "content": [{ "type": "text", "text": "POST /api/auth/logout invalidates the token" }] }]
            },
